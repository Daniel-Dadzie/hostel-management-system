# --- Java / Maven ---
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear
**/hs_err_pid*

# --- Logs ---
**/*.log

# --- Env / secrets ---
**/.env
**/.env.*
!**/.env.example

# --- IDEs ---
**/.idea/
**/*.iml
**/.classpath
**/.project
**/.settings/

# --- VS Code (keep local by default) ---
**/.vscode/

# --- OS junk ---
**/.DS_Store
**/Thumbs.db

# --- Frontend (Vite/Node) ---
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# --- Root-level node_modules (if any) ---
node_modules/

# --- Test coverage artifacts ---
coverage/
**/*.lcov
.nyc_output/
frontend/coverage/
backend/app/target/site/jacoco/

# --- Misc ---
.dist/

# --- Test files with potential secrets ---
test-*.json
*.test.json
